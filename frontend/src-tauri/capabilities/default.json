{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:8481"
    ]
  },
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "updater:default",
    "process:default",
    "dialog:default",
    "allow-select-directory",
    "allow-open-external",
    "allow-sidecar-process-alive"
  ]
}
