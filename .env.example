# Environment variables example configuration
GEMINI_API_KEY=YOUR_GEMINI_KEY
JWT_SECRET=random_32_characters
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET
DEV_MODE=true

IAM_CLIENT_ID=YOUR_CLIENT_ID
IAM_CLIENT_SECRET=YOUR_CLIENT_SECRET
IAM_URL=https://iam-api.lixionary.com
IAM_FRONTEND_URL=https://iam.lixionary.com
REDIRECT_URI=http://localhost:8481/callback

# WebSocket API URL override (optional, falls back to dynamic detection if not specified)
# NEXT_PUBLIC_WS_URL=ws://localhost:8480